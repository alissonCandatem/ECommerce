{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "SecretKey": "MBNSAVABQTRKGPQMFHLAKJCMXZXMNBVC",
    "Issuer": "ecommerce-usuarios",
    "Audience": "ecommerce",
    "ExpiresInMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "usuarios-route": {
        "ClusterId": "usuarios-cluster",
        "Match": {
          "Path": "/api/usuario/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/usuario/{**catch-all}" }
        ]
      },
      "produtos-route": {
        "ClusterId": "produtos-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/produtos/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/produtos/{**catch-all}" }
        ]
      },
      "pedidos-route": {
        "ClusterId": "pedidos-cluster",
        "AuthorizationPolicy": "default",
        "Match": {
          "Path": "/api/pedidos/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/pedidos/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "usuarios-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5101"
          }
        }
      },
      "produtos-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5102"
          }
        }
      },
      "pedidos-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5103"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}